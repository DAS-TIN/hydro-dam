{
  "name": "hydrodam",
  "productName": "Hydrodam",
  "version": "0.1.0",
  "description": "A safer git desktop client. Commit as the right person and see exactly what you are about to commit.",
  "main": "./out/main/index.js",
  "author": "Dastin Depta",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/DAS-TIN/hydro-dam.git" },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "test": "node --test test/",
    "package": "electron-vite build && electron-builder"
  },
  "build": {
    "appId": "com.hydrodam.app",
    "productName": "Hydrodam",
    "directories": { "output": "dist", "buildResources": "resources" },
    "files": ["out/**/*", "resources/**/*"],
    "win": { "target": ["nsis", "portable"], "icon": "resources/icon.png" },
    "mac": { "target": "dmg", "icon": "resources/icon.png", "category": "public.app-category.developer-tools" },
    "linux": { "target": ["AppImage"], "icon": "resources/icon.png", "category": "Development" }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
